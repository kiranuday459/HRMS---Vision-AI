# =============================================
# HRMS Backend Environment Variables — EXAMPLE
# =============================================
# Copy this file as `.env` and fill in your actual values.
# This file is safe to commit. DO NOT put real secrets here.
# =============================================

# --- Database ---
DB_URL=jdbc:postgresql://<host>:<port>/<database>?sslmode=require
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# --- Server ---
SERVER_PORT=8080

# --- Microsoft Graph API (Mail) ---
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_SENDER_EMAIL=your_sender@yourdomain.com

# --- File Upload ---
FILE_UPLOAD_DIR=uploads
